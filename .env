POSTGRES_USER=feedmind
POSTGRES_PASSWORD=feedmind_password
POSTGRES_DB=feedmind_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://feedmind:feedmind_password@postgres:5432/feedmind_db

REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_STREAM_NAME=feedback_stream
REDIS_CONSUMER_GROUP=feedmind_workers
REDIS_CACHE_PREFIX=feedmind_cache

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000

HUGGINGFACE_MODEL=distilbert-base-uncased-finetuned-sst-2-english
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
EXTERNAL_LLM_PROVIDER=groq
EXTERNAL_LLM_API_KEY=
EXTERNAL_LLM_MODEL=llama-3.1-8b-instant

INGEST_RATE_PER_MINUTE=60
FEEDBACK_SOURCE=web

ALERT_NEGATIVE_RATIO_THRESHOLD=0.5
ALERT_WINDOW_MINUTES=10
ALERT_MIN_POSTS=10
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/feedmind
LOG_LEVEL=INFO
